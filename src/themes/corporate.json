{
  "name": "Corporate",
  "description": "Gin-inspired enterprise default — cozy density, bordered cards, tertiary/primary accent pairing with a warm professional palette.",
  "density": "cozy",
  "variant": "bordered",
  "features": {
    "stickyActionBar": true,
    "collapsibleSidebar": true,
    "brandedLogin": true,
    "highContrastMode": false,
    "reducedMotion": false,
    "layoutRegions": {
      "collections": "left",
      "mediaGalleries": "left"
    }
  },
  "layoutState": {
    "leftSidebar": "full",
    "rightSidebar": "hidden",
    "pageheader": "hidden",
    "pagefooter": "hidden",
    "header": "hidden",
    "footer": "hidden"
  },
  "properties": {
    "primary": "#0f766e",
    "secondary": "#334155",
    "tertiary": "#1d4ed8",
    "success": "#16a34a",
    "warning": "#d97706",
    "error": "#dc2626",
    "surface": "#f8fafc"
  },
  "presetSource": "sveltycms-builtin"
}
