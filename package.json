{
  "name": "sveltycms",
  "version": "0.0.8",
  "description": "A powerful Headless CMS with sveltekit power",
  "keywords": [
    "AI-Powered CMS",
    "DXP Digital",
    "Developer Experience Platform",
    "best-cms",
    "cms",
    "content-management-system",
    "enterprise-cms",
    "fast-cms",
    "fastest-cms",
    "graphql",
    "headless",
    "headless-cms",
    "i18n",
    "inlang",
    "internationalization",
    "mariadb",
    "mcp-server",
    "mongodb",
    "mongodb-atlas",
    "oauth",
    "paraglide-js",
    "postgres",
    "rich-text-editor",
    "skeleton",
    "skeleton-ui",
    "svelte",
    "svelte-cms",
    "sveltekit",
    "sveltekit_cms",
    "tailwind",
    "tailwindcss",
    "tiptap",
    "wysiwyg"
  ],
  "homepage": "https://SveltyCMS.com",
  "bugs": {
    "url": "https://github.com/SveltyCMS/SveltyCMS/issues"
  },
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/SveltyCMS/SveltyCMS"
  },
  "type": "module",
  "sideEffects": [
    "*.css",
    "*.svelte"
  ],
  "scripts": {
    "-- DEVELOP -------------------------------------------": "",
    "dev": "vite dev",
    "devv": "LAUNCH_EDITOR='code' vite dev --open",
    "-- BUILD ---------------------------------------------": "",
    "build": "NODE_OPTIONS=\"--no-warnings --no-deprecation\" vp build",
    "build:verbose": "NODE_OPTIONS=\"--no-warnings --no-deprecation\" vp build",
    "build:high-memory": "NODE_OPTIONS=\"--max-old-space-size=16384\" vp build",
    "build:low-memory": "NODE_OPTIONS=\"--max-old-space-size=4096\" vp build",
    "build:analyze": "NODE_OPTIONS=\"--max-old-space-size=8192\" npx vite-bundle-visualizer && $npm_execpath run build:verbose",
    "build:report": "$npm_execpath run build:verbose && du -h .svelte-kit/output/client/_app/immutable/chunks/*.js | sort -rh | head -20",
    "build:stats": "$npm_execpath run build:verbose && bun scripts/bundle-stats.ts",
    "-- CHECK & TEST ---------------------------------------": "",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": " svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "$npm_execpath run test:unit",
    "test:unit": "svelte-kit sync && vitest",
    "test:unit:browser": "svelte-kit sync && vitest --browser.enabled",
    "test:unit:bun": "svelte-kit sync && bun run scripts/run-bun-tests.ts --preload ./tests/unit/global-setup.ts --preload ./tests/unit/bun-preload.ts",
    "test:integration": "$npm_execpath run scripts/run-integration-tests.ts",
    "test:integration:run": "$npm_execpath run scripts/run-integration-tests.ts",
    "test:integration:ci": "TEST_MODE=true $npm_execpath run scripts/run-integration-tests.ts",
    "test:hooks": "for test in authorization security-headers theme authentication firewall static-asset-caching system-state api-requests rate-limit locale setup token-resolution; do vp test run ./tests/unit/hooks/${test}.test.ts || exit 1; done",
    "test:e2e": "concurrently -k -s last \"$npm_execpath run dev\" \"$npm_execpath run test:e2e:run\"",
    "test:e2e:run": "wait-on http://127.0.0.1:5173 && npx playwright test tests/e2e",
    "test:all": "$npm_execpath run test:unit && $npm_execpath run test:integration && $npm_execpath run test:e2e",
    "test:a11y": "npx axe src/routes/(app)/config/**/*.svelte --exit",
    "-- BENCHMARKS ---------------------------------------": "",
    "benchmark": "bun run scripts/benchmark-matrix/index.ts",
    "benchmark:ci": "bun run scripts/benchmark-matrix/index.ts --ci",
    "-- LINT & FORMAT -------------------------------------": "",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "check:all": "vp check",
    "-- OTHER ----------------------------------------------": "",
    "preview": "vp preview --port 4173 --host 127.0.0.1",
    "prepare": "git config core.hooksPath .githooks",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "translate": "npx @inlang/cli machine translate --project ./project.inlang",
    "upgrade": "bun run scripts/upgrade.ts",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
