{
  "name": "sveltycms",
  "version": "0.0.7",
  "description": "A powerful Headless CMS with sveltekit power",
  "keywords": [
    "AI-Powered CMS",
    "DXP Digital",
    "Developer Experience Platform",
    "best-cms",
    "cms",
    "component-library",
    "content-management-system",
    "enterprise-cms",
    "fast-cms",
    "fastest-cms",
    "graphql",
    "headless",
    "headless-cms",
    "i18n",
    "inlang",
    "internationalization",
    "mariadb",
    "mcp-server",
    "mongodb",
    "mongodb-atlas",
    "oauth",
    "paraglide-js",
    "postgres",
    "rich-text-editor",
    "svelte",
    "svelte-cms",
    "sveltekit",
    "sveltekit_cms",
    "sveltycms",
    "tailwind",
    "tailwindcss",
    "tiptap",
    "wcag3",
    "wysiwyg"
  ],
  "homepage": "https://SveltyCMS.com",
  "bugs": {
    "url": "https://github.com/SveltyCMS/SveltyCMS/issues"
  },
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/SveltyCMS/SveltyCMS"
  },
  "type": "module",
  "sideEffects": [
    "*.css",
    "*.svelte"
  ],
  "scripts": {
    "-- DEVELOP -------------------------------------------": "",
    "dev": "vite dev",
    "devv": "LAUNCH_EDITOR='code' vite dev --open",
    "-- BUILD ---------------------------------------------": "",
    "build": "NODE_OPTIONS=\"--no-warnings --no-deprecation\" vite build",
    "build:verbose": "NODE_OPTIONS=\"--no-warnings --no-deprecation\" vite build",
    "build:high-memory": "NODE_OPTIONS=\"--max-old-space-size=16384\" vite build",
    "build:low-memory": "NODE_OPTIONS=\"--max-old-space-size=4096\" vite build",
    "build:analyze": "NODE_OPTIONS=\"--max-old-space-size=8192\" npx vite-bundle-visualizer && $npm_execpath run build:verbose",
    "build:report": "$npm_execpath run build:verbose && du -h .svelte-kit/output/client/_app/immutable/chunks/*.js | sort -rh | head -20",
    "build:stats": "npm run build:verbose && npx tsx scripts/bundle-stats.ts",
    "-- QUALITY GATES -------------------------------------": "",
    "gate:fast": "bun x lint-staged",
    "gate": "bun run scripts/quality-gate.ts",
    "ci:local": "bun run scripts/ci-local.ts",
    "-- CHECK & TEST ---------------------------------------": "",
    "format": "oxfmt",
    "check": "bun run format --check && oxlint --ignore-pattern 'src/types/**'",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "bun run test:unit",
    "test:unit": "svelte-kit sync && vitest run",
    "test:smart": "bun run scripts/test-smart.ts",
    "test:integration": "bun run scripts/run-integration-tests.ts",
    "test:e2e": "concurrently -k -s last \"$npm_execpath run dev\" \"$npm_execpath run test:e2e:run\"",
    "test:e2e:run": "wait-on http://127.0.0.1:4173 && bun x playwright test",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:e2e",
    "-- ANALYSIS -------------------------------------------": "",
    "slop": "bun run scripts/slop-scanner.ts",
    "audit:security": "bun run scripts/security-audit.ts",
    "audit:sbom": "bun run scripts/generate-sbom.ts",
    "-- LINT & FORMAT --------------------------------------": "",
    "lint": "oxlint --deny-warnings --ignore-pattern 'src/types/**'",
    "lint:docs": "bun tests/lint-docs.ts",
    "lint:admin-theme": "bun run scripts/lint-admin-theme.ts",
    "-- BENCHMARKS ----------------------------------------": "",
    "benchmark": "bun scripts/benchmark-matrix/index.ts",
    "benchmark:ci": "bun scripts/benchmark-matrix/index.ts --ci",
    "-- OTHER ----------------------------------------------": "",
    "preview": "node --no-warnings --no-deprecation build/index.js",
    "prepare": "git config core.hooksPath .githooks",
    "repair:drizzle": "node -e \"try{require('fs').accessSync('node_modules/drizzle-orm/sql/index.js');process.exit(0)}catch(e){process.exit(1)}\" || (npm remove drizzle-orm 2>/dev/null; npm install drizzle-orm)",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "translate": "npx @inlang/cli machine translate --project ./project.inlang",
    "upgrade": "npx tsx scripts/upgrade.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
