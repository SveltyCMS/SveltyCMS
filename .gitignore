# sveltekit
/build

# bun-generated type stubs (local artifacts, not tracked)
src/types/*/
/.svelte-kit
/package
# Lock files — bun is the recommended package manager; commit its lock file.
# npm, yarn, and pnpm users generate their own locally.
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb
# Visual regression snapshot baselines (generated locally, committed separately)
**/*-snapshots/
node_modules
.bun-cache
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# secrets
.env
.env.*
/config/*
!/config/aliases.json
/data.json
.bundle-history.json

# Backup folder under config
/config/backup/
/config/database

