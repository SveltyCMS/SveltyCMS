{
  "src/**/*.{ts,js,svelte.ts}": [
    "oxfmt",
    "oxlint --deny-warnings",
    "bun run scripts/slop-scanner.ts --strict --files"
  ],
  "src/**/*.svelte": ["bun run scripts/slop-scanner.ts --strict --files"],
  "src/routes/(app)/**/*.svelte": ["bun run scripts/lint-admin-theme.ts"],
  "docs/**/*.{md,mdx}": ["bun run tests/lint-docs.ts"]
}
