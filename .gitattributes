# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly handle common web files
*.js text eol=lf
*.ts text eol=lf
*.svelte text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.mdx text eol=lf

# Keep binary files as-is
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text eol=lf
*.ico binary
*.pdf binary
