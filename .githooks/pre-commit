#!/usr/bin/env sh
# =============================================================================
# SveltyCMS Pre-Commit — Fast Loop (~2-3s)
# =============================================================================
# Runs scripts/pre-commit-lint.ts which executes all checks SEQUENTIALLY
# in a single bun process to avoid OOM/SIGKILL on Windows (lint-staged
# spawns too many parallel processes).
#
# Checks: oxfmt, oxlint, slop-scanner on source files;
#         lint-admin-theme on (app) svelte files;
#         lint-docs on documentation files.
#
# Heavy checks (type check, unit tests) are deferred to pre-push.
# Production builds and integration tests are CI-only.
#
# POLICY: --no-verify is blocked. Use 'bun run scripts/git-safe.ts commit' instead.
# In a true emergency, use the full path to raw git: /usr/bin/git commit --no-verify
# =============================================================================
set -e

if [ "${CI:-false}" = "true" ]; then
    echo "⏩ CI environment detected. Bypassing pre-commit gates."
    exit 0
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║       SveltyCMS Pre-Commit — Fast Loop (~2-3s)             ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

bun run scripts/pre-commit-lint.ts
