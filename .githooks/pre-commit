#!/usr/bin/env sh
# =============================================================================
# SveltyCMS Pre-Commit — Fast Loop (~2-3s)
# =============================================================================
# Runs on STAGED FILES ONLY via lint-staged (.lintstagedrc.json):
#   • oxfmt (auto-format), oxlint --deny-warnings, slop-scanner (src/**)
#   • lint-admin-theme (src/routes/(app)/**)
#   • lint-docs (docs/**)
#   • check-test-db-safety (pre-check)
#
# Full gate runs on pre-push via scripts/precheck.ts (push tier):
#   • static analysis, lint, unit tests, production build
#   • progress dashboard with ETA and error remediation
#   • DB integration + benchmarks are CI-only (opt in: --include-db-tasks)
#
# POLICY: --no-verify is blocked. Use 'bun run scripts/git-safe.ts commit'.
# =============================================================================
set -euo pipefail

if [ "${CI:-false}" = "true" ]; then
    echo "⏩ CI environment detected. Bypassing pre-commit gates."
    exit 0
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════════════════════╗"
echo "║       SveltyCMS Pre-Commit — Fast Loop (~2-3s)             ║"
echo "╚══════════════════════════════════════════════════════════════════════════════╝"
echo ""

# Step 1: Check test database safety
bun run scripts/check-test-db-safety.ts

# Step 2: Format all files (catches formatting drift like bun.lock)
echo "🔍 Checking formatting..."
bun run format --check || {
    echo "❌ Formatting issues detected. Auto-fixing..."
    bun run format
    echo "✅ Files formatted. Please review and stage the changes."
    exit 1
}

# Step 3: Run lint-staged on staged files
bun run gate:fast

echo "✅ All pre-commit checks passed!"
