#!/usr/bin/env sh
# =============================================================================
# SveltyCMS Pre-Commit — Fast Loop (~2-3s)
# =============================================================================
# Runs on STAGED FILES ONLY via lint-staged:
#   • oxfmt, oxlint, slop-scanner (src)
#   • lint-docs (docs)
#   • check-test-db-safety (config/private.test.ts guard)
#
# Full gate runs on push via scripts/precheck.ts (build + 4-DB integration + benchmarks).
#
# POLICY: --no-verify is blocked. Use 'bun run scripts/git-safe.ts commit'.
# =============================================================================
set -e

if [ "${CI:-false}" = "true" ]; then
    echo "⏩ CI environment detected. Bypassing pre-commit gates."
    exit 0
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║       SveltyCMS Pre-Commit — Fast Loop (~2-3s)             ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

bun run scripts/check-test-db-safety.ts

bun x lint-staged