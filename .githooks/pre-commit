#!/usr/bin/env sh
set -e

# Skip git hooks in CI environments to avoid unnecessary overhead and failures
if [ "$CI" = "true" ]; then
    echo "⏩ CI environment detected. Skipping pre-commit hooks."
    exit 0
fi

# Run the high-performance parallel quality gate
bun run scripts/quality-gate.ts

# Run the documentation linter
bun run lint:docs

# Ensure any automatic fixes (fmt/lint) are added to the commit
git add src tests docs scripts
