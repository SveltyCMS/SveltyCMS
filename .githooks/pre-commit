#!/usr/bin/env sh
set -e

echo "🔍 Running pre-commit checks (Native Git Hook)..."

# Find staged files (filters out deleted files) to pass to linters
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|js|svelte|json|md)$' || true)

if [ -n "$STAGED_FILES" ]; then
    echo "✨ Formatting & ⚡ Linting (Vite+ on staged files)..."
    echo "$STAGED_FILES" | xargs bunx oxfmt --write
    echo "$STAGED_FILES" | xargs bunx oxlint --fix

    # Re-stage files in case Vite+ fixed formatting/linting issues automatically
    echo "$STAGED_FILES" | xargs git add
else
    echo "⏩ No relevant staged files found for formatting/linting."
fi

# 2. Type Check (Svelte Check)
# Temporarily disabled due to TypeScript 6.0 compatibility issues with svelte-check
# echo "✅ Type Checking..."
# bun run check

# 3. Unit Tests (Fast Bun)
echo "🧪 Testing (Bun Native)..."
bun run test:unit:bun

echo "✨ Pre-commit checks passed!"
