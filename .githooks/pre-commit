#!/usr/bin/env sh
# =============================================================================
# SveltyCMS Pre-Commit Quality Gate — Fast checks only (seconds)
# =============================================================================
# Pre-commit runs only fast checks: format, lint, type-check.
# Heavy checks (unit tests, build, integration, E2E) are deferred to pre-push.
#
# Skip with: git commit --no-verify
# =============================================================================
set -e

if [ "${CI:-false}" = "true" ]; then
    echo "⏩ CI environment detected. Bypassing pre-commit gates."
    exit 0
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║           SveltyCMS Pre-Commit Quality Gate (fast)           ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

echo "▶️  Format"
bun run format

# Re-stage files modified by formatter
staged_after_fix=$(git diff --cached --name-only --diff-filter=ACMR || true)
if [ -n "$staged_after_fix" ]; then
    printf '%s\n' "$staged_after_fix" | while IFS= read -r file; do
        if [ -f "$file" ]; then
            git add "$file"
        fi
    done
fi

# Verify tree is clean after formatting
if ! git diff --exit-code --quiet; then
    echo "❌ Working tree is dirty after formatting. Re-stage and try again."
    exit 1
fi

echo "▶️  Lint"
bun run lint

echo "▶️  Type Check"
bun run check

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  ✅ Fast checks passed. Run 'git push' for full validation.  ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""
