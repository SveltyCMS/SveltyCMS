#!/usr/bin/env sh
# =============================================================================
# SveltyCMS Pre-Commit — Format → Lint → Unit (~40s)
#
# Pre-push runs build + SQLite integration.
# POLICY: --no-verify is blocked. Use 'bun run scripts/git-safe.ts commit'.
# =============================================================================
set -u
[ "${CI:-false}" = "true" ] && exit 0

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "$SCRIPT_DIR/lib.sh"

header "Pre-Commit"
require_bun

TOTAL=4; OK=0

# Step 1 — Database safety
if run "🛡️  Database safety" $RUN_CMD scripts/check-test-db-safety.ts; then
  OK=$((OK + 1))
fi

# Step 2 — Format + lint
if run "🔍  Format + lint" $RUN_CMD check; then
  OK=$((OK + 1))
else
  $RUN_CMD format > /dev/null 2>&1
  git add -u 2>/dev/null || true
  if run "🔍  Re-checking after format" $RUN_CMD check; then
    warn "Files auto-formatted and staged."
    OK=$((OK + 1))
  else
    warn "Lint errors remain after formatting."
  fi
fi

# Step 3 — Lint-staged
if run "⚡  Lint-staged" $RUN_CMD gate:fast; then
  OK=$((OK + 1))
fi

# Step 4 — Unit tests (skip if only docs changed)
if has_changes '\.(md|mdx)$' && ! has_changes '\.(ts|js|svelte)$'; then
  warn "Only docs changed — skipping unit tests"
  TOTAL=$((TOTAL - 1))
  OK=$((OK + 1))
elif run "🧪  Unit tests" $RUN_CMD test:unit; then
  OK=$((OK + 1))
fi

summary "$OK" "$TOTAL"
