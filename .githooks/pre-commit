#!/usr/bin/env sh
# =============================================================================
# SveltyCMS Pre-Commit — Fast Loop (~2-3s)
# =============================================================================
# Test ownership (never run the same suite on pre-push):
#   • Security regression → THIS hook only (scripts/security-regression.ts)
#   • Smart unit / build  → pre-push only
#
# Also: check-test-db-safety, format, lint-staged (fmt/lint/slop on staged files).
#
# Pre-push (scripts/precheck.ts push tier): typecheck, imports, unit (excludes
# security files), production build. DB matrix is CI-only.
#
# POLICY: --no-verify is blocked. Use 'bun run scripts/git-safe.ts commit'.
# =============================================================================
set -euo pipefail

if [ "${CI:-false}" = "true" ]; then
    echo "⏩ CI environment detected. Bypassing pre-commit gates."
    exit 0
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════════════════════╗"
echo "║       SveltyCMS Pre-Commit — Fast Loop (~2-3s)             ║"
echo "╚══════════════════════════════════════════════════════════════════════════════╝"
echo ""

# Step 1: Check test database safety
echo "[1/4] 🛡️  Checking test database safety..."
bun run scripts/check-test-db-safety.ts

# Step 2: Format all files (catches formatting drift like bun.lock)
echo "[2/4] 🔍 Checking formatting..."
bun run format --check || {
    echo "❌ Formatting issues detected. Auto-fixing..."
    bun run format
    echo "✅ Files formatted. Please review and stage the changes."
    exit 1
}

# Step 3: Run lint-staged on staged files
echo "[3/4] ⚡ Running lint-staged on staged files..."
bun run gate:fast

# Step 4: Security regression — PRE-COMMIT ONLY (pre-push excludes these files)
echo "[4/4] 🔒 Running security regression tests (pre-commit only)..."
bun run scripts/security-regression.ts || {
    echo "❌ Security regression tests FAILED. Fix before committing."
    echo "   Run manually: bun run scripts/security-regression.ts"
    exit 1
}

echo "✅ All pre-commit checks passed!"
