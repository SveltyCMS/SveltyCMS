#!/usr/bin/env sh
# =============================================================================
# SveltyCMS Pre-Push — Full CI Core Gate (~15-45min)
# =============================================================================
# Runs scripts/precheck.ts (push tier) before code reaches GitHub:
#   • format, lint, slop, imports, unit tests (always)
#   • production build + 4-DB integration + core benchmarks (when code/infra changed)
#
# Requires Docker Desktop with DB containers on 127.0.0.1 (see tests/docker-compose.yml).
# Full CI (+ E2E): bun run ci:local
#
# POLICY: --no-verify is blocked. Use 'bun run scripts/git-safe.ts push'.
# =============================================================================
set -e

if [ "${CI:-false}" = "true" ]; then
    echo "⏩ CI environment detected. Bypassing pre-push gates."
    exit 0
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║     SveltyCMS Pre-Push — CI Core Gate (4-DB + benchmarks)    ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

bun run verify:push