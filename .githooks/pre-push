#!/usr/bin/env sh
# =============================================================================
# SveltyCMS Pre-Push Quality Gate — Heavy validation (minutes)
# =============================================================================
# Runs unit tests, production build, integration tests, and E2E tests.
# Fast checks (format, lint, type-check) are already done by pre-commit.
#
# Skip with: git push --no-verify
# =============================================================================
set -e

if [ "${CI:-false}" = "true" ]; then
    echo "⏩ CI environment detected. Bypassing pre-push gates (CI will enforce anyway)."
    exit 0
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║             SveltyCMS Pre-Push Quality Gate (heavy)          ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

# ── Gate 1: Unit Tests ────────────────────────────────────────────────────
echo "🛡️  Gate 1: Unit Tests"
bun run test:unit
echo "   ✓ Unit tests passed."
echo ""

# ── Config backup for clean CI-like environment ───────────────────────────
echo "💾 Backing up local configuration..."
mkdir -p .tmp_config_backup
if [ -f config/private.ts ]; then cp config/private.ts .tmp_config_backup/private.ts; fi
if [ -f config/private.test.ts ]; then cp config/private.test.ts .tmp_config_backup/private.test.ts; fi
if [ -d config/database ]; then cp -r config/database .tmp_config_backup/database; fi

restore_config() {
    echo "⏪ Restoring local configuration..."
    if [ -d .tmp_config_backup/database ]; then
        rm -rf config/database
        cp -r .tmp_config_backup/database config/database
    fi
    if [ -f .tmp_config_backup/private.ts ]; then cp .tmp_config_backup/private.ts config/private.ts; else rm -f config/private.ts; fi
    if [ -f .tmp_config_backup/private.test.ts ]; then cp .tmp_config_backup/private.test.ts config/private.test.ts; else rm -f config/private.test.ts; fi
    rm -rf .tmp_config_backup
    echo "   ✓ Local configuration restored."
}

trap restore_config EXIT INT TERM

rm -rf config/private.ts config/private.test.ts config/database/* tests/e2e/.auth/user.json logs/* || true

# ── Gate 2: Production Build ─────────────────────────────────────────────
echo "🏗️  Gate 2: Production Build"
rm -rf build .svelte-kit
COMPILE_ALL_ADAPTERS=true bun run build
echo "   ✓ Build completed."
echo ""

# ── Gate 3: SQLite Integration Tests ─────────────────────────────────────
echo "🛡️  Gate 3: SQLite Integration Tests"
bun run scripts/run-integration-tests.ts --db=sqlite --no-build
echo "   ✓ Integration tests passed."
echo ""

# ── Gate 4: Playwright E2E Tests ─────────────────────────────────────────
echo "🎭 Gate 4: Playwright E2E Tests"
bun x playwright install --with-deps chromium 2>/dev/null || true
bun x playwright test --project=wizard --project=auth-setup --project=signup --project=content --project=system --project=a11y --project=rbac --project=language
echo "   ✓ Playwright tests passed."
echo ""

echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  ✅ All pre-push gates passed. Push allowed.                 ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""
