#!/usr/bin/env sh
# =============================================================================
# SveltyCMS Pre-Push — Fast Gate (change-scoped, ~1–3 min typical)
# =============================================================================
# Test ownership (never re-run pre-commit suites):
#   • Security regression → pre-commit only (excluded from push unit run)
#   • Smart unit tests    → this hook only
#   • HTTP integration    → CI only (opt-in: --include-db-tasks)
#
# Also: Diff base = @{upstream}/origin/next; typecheck/imports/slop when needed;
# one production build when source/infra changes; deploy double-build only when
# vite/testing-strip paths change.
#
# Opt in heavier local: bun run scripts/precheck.ts --tier=push --include-db-tasks
# POLICY: --no-verify is blocked. Use 'bun run scripts/git-safe.ts push'.
# =============================================================================
set -euo pipefail

if [ "${CI:-false}" = "true" ]; then
    echo "⏩ CI environment detected. Bypassing pre-push gates."
    exit 0
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║   SveltyCMS Pre-Push — Fast Gate + Progress Dashboard       ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

bun run verify:push
