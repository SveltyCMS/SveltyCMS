#!/usr/bin/env sh
# =============================================================================
# SveltyCMS Pre-Push — Fast Gate (~5-10s)
# =============================================================================
# Runs scripts/precheck.ts (push tier) before code reaches GitHub:
#   • format, lint, slop, imports, unit tests (always)
#   • production build (always on any change)
#   • progress dashboard with ETA, per-task timing, and error remediation
#
# 4-DB integration + benchmarks run in CI only (bun run ci:local for local).
#
# POLICY: --no-verify is blocked. Use 'bun run scripts/git-safe.ts push'.
# =============================================================================
set -euo pipefail

if [ "${CI:-false}" = "true" ]; then
    echo "⏩ CI environment detected. Bypassing pre-push gates."
    exit 0
fi

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║   SveltyCMS Pre-Push — Fast Gate + Progress Dashboard       ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

bun run verify:push
