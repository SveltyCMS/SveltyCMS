{
  "schema": {
    "_id": "blog_posts",
    "name": "Blog Posts",
    "icon": "mdi:post",
    "fields": [
      {
        "db_fieldName": "title",
        "label": "Title",
        "widget": "input",
        "required": true,
        "translated": true
      },
      {
        "db_fieldName": "content",
        "label": "Content",
        "widget": "richText",
        "required": true,
        "translated": true
      },
      {
        "db_fieldName": "author",
        "label": "Author",
        "widget": "relation",
        "relation": "auth_users",
        "displayField": "username"
      }
    ]
  },
