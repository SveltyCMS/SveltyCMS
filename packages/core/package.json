{
  "name": "@sveltycms/core",
  "version": "0.0.7",
  "description": "SveltyCMS Core — database-agnostic CMS engine with LocalCMS SDK, type-safe DB adapter interfaces, and enterprise auth primitives.",
  "keywords": [
    "cms",
    "database-agnostic",
    "enterprise",
    "headless-cms",
    "multi-tenant",
    "svelte",
    "sveltekit",
    "typescript"
  ],
  "homepage": "https://sveltycms.com",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/SveltyCMS/SveltyCMS",
    "directory": "packages/core"
  },
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./db-interface": {
      "types": "./src/db-interface.ts",
      "import": "./src/db-interface.ts",
      "default": "./src/db-interface.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "import": "./src/errors.ts",
      "default": "./src/errors.ts"
    },
    "./local-cms": {
      "types": "./src/local-cms.ts",
      "import": "./src/local-cms.ts",
      "default": "./src/local-cms.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "valibot": "^1.4.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
