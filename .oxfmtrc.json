{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "ignorePatterns": [
    "node_modules/**",
    "build/**",
    "dist/**",
    ".svelte-kit/**",
    "src/paraglide/**",
    "src/live/$types.d.ts",
    ".compiledCollections/**",
    "coverage/**",
    "sbom.json"
  ]
}
